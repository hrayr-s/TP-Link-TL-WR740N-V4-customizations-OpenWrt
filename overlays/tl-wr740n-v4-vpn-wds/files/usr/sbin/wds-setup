#!/bin/sh
set -eu

usage() {
	cat <<'EOF'
Usage:
  wds-setup <upstream-ssid> <upstream-key> [local-ssid] [local-key] [country]

Configures radio0 as a WDS station bridged to LAN. If local-ssid and local-key
are provided, it also creates a local AP on the same radio/channel.

The upstream AP must support WDS/4-address bridging. The radio channel is set
to auto; in station/WDS mode it follows the upstream AP channel.
EOF
}

[ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && { usage; exit 0; }
[ "$#" -ge 2 ] || { usage >&2; exit 2; }

UPSTREAM_SSID="$1"
UPSTREAM_KEY="$2"
LOCAL_SSID="${3:-}"
LOCAL_KEY="${4:-}"
COUNTRY="${5:-00}"

[ -f /etc/config/wireless ] || wifi config

while uci -q delete wireless.@wifi-iface[0]; do :; done

uci set wireless.radio0.disabled='0'
uci set wireless.radio0.channel='auto'
uci set wireless.radio0.country="$COUNTRY"
uci set wireless.radio0.htmode='HT20'

uci set wireless.wds_sta='wifi-iface'
uci set wireless.wds_sta.device='radio0'
uci set wireless.wds_sta.mode='sta'
uci set wireless.wds_sta.network='lan'
uci set wireless.wds_sta.ssid="$UPSTREAM_SSID"
uci set wireless.wds_sta.encryption='psk2'
uci set wireless.wds_sta.key="$UPSTREAM_KEY"
uci set wireless.wds_sta.wds='1'

if [ -n "$LOCAL_SSID" ]; then
	[ -n "$LOCAL_KEY" ] || { echo "local-key is required when local-ssid is set" >&2; exit 2; }
	uci set wireless.wds_ap='wifi-iface'
	uci set wireless.wds_ap.device='radio0'
	uci set wireless.wds_ap.mode='ap'
	uci set wireless.wds_ap.network='lan'
	uci set wireless.wds_ap.ssid="$LOCAL_SSID"
	uci set wireless.wds_ap.encryption='psk2'
	uci set wireless.wds_ap.key="$LOCAL_KEY"
	uci set wireless.wds_ap.wds='1'
fi

uci commit wireless
wifi reload

echo "WDS configuration applied."
echo "Check link state with: wifi status"
